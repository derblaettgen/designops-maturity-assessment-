        { "id": "d6_2", "text": "UX-Metriken (SUS, NPS, Task Success) werden regelmäßig erhoben.", "type": "likert", "req": true },
        { "id": "d6_3", "text": "DesignOps-Metriken (Velocity, Rework Rate) werden gemessen.", "type": "likert", "req": true },
        { "id": "d6_4", "text": "Der Design-ROI kann nachgewiesen und kommuniziert werden.", "type": "likert", "req": true }
