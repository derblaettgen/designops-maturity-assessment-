        { "id": "d3_3", "text": "Es gibt Automatisierungen (Plugins, CI/CD für Design-Assets).", "type": "likert", "req": true },
        { "id": "d3_4", "text": "Neue Tools werden nach strukturiertem Prozess evaluiert.", "type": "likert", "req": true },
        { "id": "d3_5", "text": "KI-gestützte Tools werden aktiv eingesetzt.", "type": "likert", "req": true },
