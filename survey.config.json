      "title": "Dimension 4: Design System",
      "desc": "Existenz, Governance, Adoption und Code-Synchronisation.",
      "questions": [
        { "id": "d4_1", "text": "Es existiert ein dokumentiertes, gepflegtes Design System.", "type": "likert", "req": true },
