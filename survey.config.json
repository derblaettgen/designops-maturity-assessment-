        { "id": "d4_3", "text": "Das Design System wird von >70 % der Teams aktiv genutzt.", "type": "likert", "req": true },
        { "id": "d4_4", "text": "Design Tokens / Komponenten sind zwischen Tool und Code synchronisiert.", "type": "likert", "req": true },
        { "id": "d4_5", "text": "Das System deckt Patterns, Guidelines und Content-Standards ab.", "type": "likert", "req": true },
        { "id": "d4_6", "text": "Qualität und Aktualität werden regelmäßig gemessen.", "type": "likert", "req": true }
      ]
    },
    {
      "id": "d56",
