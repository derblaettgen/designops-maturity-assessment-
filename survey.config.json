    {
      "id": "d1",
      "icon": "👥",
      "title": "Dimension 1: People & Team",
      "desc": "Teamstruktur, Karrierepfade, Weiterbildung und Community.",
      "questions": [
        { "id": "d1_1", "text": "Es gibt klar definierte Rollen und Verantwortlichkeiten im Design-Team.", "type": "likert", "req": true },
        { "id": "d1_2", "text": "Es existiert ein standardisierter Onboarding-Prozess für Designer:innen.", "type": "likert", "req": true },
        { "id": "d1_3", "text": "Es gibt definierte Karrierepfade und Kompetenzmodelle (Career Ladder).", "type": "likert", "req": true },
        { "id": "d1_4", "text": "Regelmäßige Weiterbildungsmöglichkeiten sind vorhanden (Schulungen, Konferenzen, Budget).", "type": "likert", "req": true },
        { "id": "d1_5", "text": "Es gibt eine aktive Design-Community (CoP, Guild, Meetups).", "type": "likert", "req": true },
        { "id": "d1_6", "text": "Zufriedenheit und Engagement werden regelmäßig erfasst.", "type": "likert", "req": true },
        { "id": "d1_t", "text": "Kommentar: Größte Herausforderung People & Team?", "type": "textarea", "req": false }
      ]
    },
    {
      "id": "d2",
      "icon": "⚙️",
      "title": "Dimension 2: Prozesse & Workflows",
      "desc": "Standardisierung, Handoffs, Reviews und Kapazitätsplanung.",
      "questions": [
        { "id": "d2_1", "text": "Design-Prozesse sind dokumentiert und zugänglich.", "type": "likert", "req": true },
        { "id": "d2_2", "text": "Es gibt einen definierten Handoff-Prozess (Design → Dev).", "type": "likert", "req": true },
        { "id": "d2_3", "text": "Reviews und Freigaben sind strukturiert und regelmäßig.", "type": "likert", "req": true },
        { "id": "d2_4", "text": "Es gibt systematische Kapazitäts- und Ressourcenplanung.", "type": "likert", "req": true },
        { "id": "d2_5", "text": "Design ist in agile Frameworks integriert.", "type": "likert", "req": true },
        { "id": "d2_6", "text": "Wiederkehrende Aufgaben sind durch Templates/Automatisierungen vereinfacht.", "type": "likert", "req": true }
      ]
    },
    {
      "id": "d3",
